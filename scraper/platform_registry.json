{
  "version": 1,
  "description": "Crowdfunding/charity platform scrape matrix. See SCRAPER_PLATFORM_MATRIX.md for full ~150 list.",
  "platforms": [
    {
      "id": "gofundme",
      "name": "GoFundMe",
      "region": "global",
      "scrape_method": "algolia",
      "search_method": "algolia_text",
      "env_keys": ["GFM_ALGOLIA_APP_ID", "GFM_ALGOLIA_API_KEY"],
      "base_url": "https://www.gofundme.com",
      "notes": "Index prod_funds_feed_replica_1; capture keys from /discover or /s?q="
    },
    {
      "id": "launchgood",
      "name": "LaunchGood",
      "region": "global_muslim",
      "scrape_method": "discover",
      "search_method": "search_url",
      "base_url": "https://www.launchgood.com",
      "search_url_template": "https://www.launchgood.com/search?q={query}",
      "discover_urls": ["https://www.launchgood.com/discover", "https://www.launchgood.com/explore"],
      "link_markers": ["/campaign/", "/project/"]
    },
    {
      "id": "globalgiving",
      "name": "GlobalGiving",
      "region": "global",
      "scrape_method": "official_api",
      "search_method": "api_q",
      "env_keys": ["GLOBALGIVING_API_KEY"],
      "base_url": "https://www.globalgiving.org",
      "notes": "GET /api/public/services/search/projects/summary?q="
    },
