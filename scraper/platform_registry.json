  "platforms": [
    {
      "id": "gofundme",
      "name": "GoFundMe",
      "region": "global",
      "scrape_method": "algolia",
      "search_method": "algolia_text",
      "env_keys": ["GFM_ALGOLIA_APP_ID", "GFM_ALGOLIA_API_KEY"],
      "base_url": "https://www.gofundme.com",
      "notes": "Index prod_funds_feed_replica_1; capture keys from /discover or /s?q="
