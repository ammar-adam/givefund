PORT=8000
DB_PATH=./givefund.db

# Optional: save donor cards via Stripe Checkout (setup mode, no charge)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# Optional: Google Sign-In for donor identity (OAuth ID token verify)
# GOOGLE_CLIENT_ID=

# Frontend URL for Stripe redirect callbacks
# GIVEFUND_FRONTEND_URL=http://127.0.0.1:5500

# GlobalGiving API (free registration) — enables globalgiving scraper
# GLOBALGIVING_API_KEY=

# Live ingestion (production: LIVE_SCRAPE=true in start_prod.sh)
LIVE_SCRAPE=true
SCRAPE_INTERVAL=1800
SCRAPE_PARALLEL=4
SCRAPE_ON_START=true
MIN_CAMPAIGNS=10000
SCALE_TARGET=10000
GFM_ALGOLIA_ONLY=true
GFM_MAX_ALGOLIA_PAGES=100

# Frontend URL for Stripe redirect callbacks
# GIVEFUND_FRONTEND_URL=https://your-site.vercel.app

# GoFundMe Algolia (required for production scrapes — capture from browser DevTools)
# GFM_ALGOLIA_APP_ID=
# GFM_ALGOLIA_API_KEY=
# GFM_ALGOLIA_ONLY=true
# GFM_MAX_ALGOLIA_PAGES=60
# LAUNCHGOOD_MAX_ENRICH=120
# DISCOVER_MAX_CAMPAIGNS=200

# Live search (user query → scrape all platforms on demand)
# LIVE_SEARCH_LIMIT_PER_PLATFORM=50
# LIVE_SEARCH_PARALLEL=5
# LIVE_SEARCH_TIMEOUT_SEC=180

# GoFundMe scraper: set after one successful browser capture (DevTools → Algolia request headers)
# GFM_ALGOLIA_APP_ID=
# GFM_ALGOLIA_API_KEY=
# GFM_ALGOLIA_ONLY=true
