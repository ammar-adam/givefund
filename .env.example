PORT=8000
DB_PATH=./givefund.db

# Frontend origin for Stripe Checkout redirects (no trailing slash)
GIVEFUND_FRONTEND_URL=http://127.0.0.1:5500

# Stripe — enable optional Link enrollment via /checkout/link-setup
# Dashboard: enable Link under Settings → Payment methods
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# GoFundMe scraper: set after one successful browser capture (DevTools → Algolia request headers)
# GFM_ALGOLIA_APP_ID=
# GFM_ALGOLIA_API_KEY=
# GFM_ALGOLIA_ONLY=true
